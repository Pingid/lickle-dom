{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node10",
    "module": "commonjs",
    "outDir": "lib/cjs",
    "noEmit": false,
    "rootDir": "src"
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts", "build", "test"]
}
