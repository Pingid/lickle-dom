{
  "name": "@lickle/dom",
  "description": "Library of dom utility functions",
  "version": "0.2.1",
  "author": "Dan Beaven <dm.beaven@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pingid/lickle-dom.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "lib/cjs/index.js",
  "types": "lib/ts/index.d.ts",
  "module": "lib/esm/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./lib/ts/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./build": {
      "types": "./build/ts/index.d.ts",
      "import": "./build/esm/index.js",
      "require": "./build/cjs/index.js"
    }
  },
  "scripts": {
    "build": "pnpm tsc && pnpm build:tools && pnpm build:lib",
    "build:tools": "tsc -p ./build/tsconfig.json && tsc -p ./build/tsconfig.cjs.json",
    "build:lib": "tsc -p ./tsconfig.esm.json && tsc -p ./tsconfig.cjs.json",
    "format": "prettier --write .",
    "generate": "npm run build:tools && node ./generate.js"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120,
    "trailingComma": "all"
  }
}
